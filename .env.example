# Copy this file to backend/.env and fill in your values.
# Never commit .env to version control.

# PostgreSQL connection string (required)
DATABASE_URL=postgresql://user:password@localhost:5432/chelsea_poker

# For running tests against a separate test database (required for npm test)
TEST_DATABASE_URL=postgresql://user:password@localhost:5432/chelsea_poker_test

# Port the server listens on (optional, defaults to 3000)
PORT=3000
